{
  "name": "Foundry Workflow",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },
  "postCreateCommand": "pip install --upgrade pip && pip install azure-ai-projects azure-identity python-dotenv",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "redhat.vscode-yaml",
        "TeamsDevApp.vscode-ai-foundry"
      ]
    }
  },
  "remoteEnv": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
