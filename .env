# ─────────────────────────────────────────────────────────────────────────────
# Foundry Workflow — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# This file is used by: scripts/setup_agents.py
# If you create agents manually via the Foundry portal, you do NOT need this.
# ─────────────────────────────────────────────────────────────────────────────

# ── Foundry Project (REQUIRED) ───────────────────────────────────────────────
# Format: https://<resource_name>.ai.azure.com/api/projects/<project_name>
FOUNDRY_PROJECT_ENDPOINT=https://cog-tb7tpjtuee4ji.services.ai.azure.com/api/projects/cog-tb7tpjtuee4ji-project

# ── Model Deployment (REQUIRED) ──────────────────────────────────────────────
# Name of your deployed model (e.g., gpt-4o, gpt-4o-mini)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# ── Bing Connection (REQUIRED for Agent 1) ───────────────────────────────────
# Create a Bing Search connection in your Foundry project Settings > Connections
# then enter the connection name below.
BING_CONNECTION_NAME=groundingwithbingagents

# ── Authentication ────────────────────────────────────────────────────────────
# Uses DefaultAzureCredential (az login / managed identity / service principal).
# To use service principal auth instead, uncomment and fill:
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
